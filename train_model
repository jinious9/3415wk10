import re
import joblib
import pandas as pd
from sentence_transformers import SentenceTransformer
from sklearn.linear_model import LogisticRegression

CSV_FILE = "converted_file.csv"
MODEL_FILE = "best_classifier.joblib"
BERT_MODEL_NAME = "all-MiniLM-L6-v2"

def clean_text(text):
    text = str(text).lower()
    text = re.sub(r"http\S+|www\S+", " ", text)
    text = re.sub(r"[^a-z0-9\s]", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text

# Load dataset
df = pd.read_csv(CSV_FILE)

# Prepare text and labels
df["text"] = df["Summary"].fillna("").astype(str) + " " + df["Review"].fillna("").astype(str)
df["text"] = df["text"].apply(clean_text)
df["label"] = df["Sentiment"].astype(str).str.lower().str.strip()

df = df[df["label"].isin(["positive", "negative", "neutral"])]
df = df[df["text"].str.len() > 0]

print("Rows used:", len(df))
print(df["label"].value_counts())

# Load BERT encoder
bert_encoder = SentenceTransformer(BERT_MODEL_NAME)

# Convert text into embeddings
X_bert = bert_encoder.encode(df["text"].tolist(), show_progress_bar=True)

# Train classifier
clf = LogisticRegression(max_iter=1000)
clf.fit(X_bert, df["label"])

# Save classifier only
joblib.dump(clf, MODEL_FILE)

print(f"Model trained with BERT embeddings and saved as {MODEL_FILE}")